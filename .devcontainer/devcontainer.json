// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "Seqnado Dev Container",
	"build": {
		// Context is repo root so the Dockerfile can access containers/pipeline/
		"context": "..",
		"dockerfile": ".devcontainer/Dockerfile"
	},
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
	"workspaceFolder": "/workspace",
	"remoteUser": "root",
	// Install seqnado in editable mode and pytest after container starts
	"postCreateCommand": "uv pip install --system -e . pytest"

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {}
}
